# 1) 进入脚本目录并备份旧配置
cd /Volumes/MyPassport/multiomics_mech/scripts
cp 00_config.env 00_config.env.bak 2>/dev/null || true

# 2) 重写为标准配置（UTF-8、无奇怪编码）
cat > 00_config.env <<'EOF'
# === 基本路径 ===
PROJECT_DIR="/Volumes/MyPassport/multiomics_mech"
RAW="$PROJECT_DIR/data/raw/rna"
INTERIM="$PROJECT_DIR/data/interim/rna"
PROCESSED="$PROJECT_DIR/data/processed/rna"
QC_OUT="$PROJECT_DIR/results/qc/rna"
REF_DIR="$PROJECT_DIR/ref"

# === 线程与链特异性 ===
THREADS=8
# 0=非链特异；1=第一链；2=第二链（不确定先用0）
STRANDNESS=0

# === 参考文件（Ensembl GRCm39 / rel-109）===
GENOME_FA="$REF_DIR/Mus_musculus.GRCm39.dna.primary_assembly.fa.gz"
GTF="$REF_DIR/Mus_musculus.GRCm39.109.gtf.gz"
STAR_INDEX="$REF_DIR/star_index"

# === 要处理的批次 ===
BATCHES=("batch1" "batch2" "batch3")

# === R1 匹配模式（兼容 .fastq.gz 与 .fq.gz）===
#    同时支持 *_R1*.f*q.gz 与 *_1.f*q.gz
R1_PATTERNS=("*_R1*.f*q.gz" "*_1.f*q.gz")
EOF

# 3)（可选）去掉可能混入的 CR/LF
perl -i -pe 's/\r$//' 00_config.env

# 4) 让 03_star_index.sh 明确用 bash 调用（更稳）
# 当前文件里是一个裸字符串行，换成 bash 调用更不容易出意外
cat > 03_star_index.sh <<'EOF'
#!/usr/bin/env bash
set -euo pipefail
bash "$(dirname "$0")/00_fetch_reference.sh"
EOF
chmod +x 03_star_index.sh

# 5) 重新跑索引（会自动下载参考并构建；已存在则跳过）
bash scripts/03_star_index.sh