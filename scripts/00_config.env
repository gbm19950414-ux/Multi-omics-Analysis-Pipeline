# === 基本路径（已按你的项目固定）===
PROJECT_DIR="/Volumes/MyPassport/multiomics_mech"
RAW="$PROJECT_DIR/data/raw/rna"
INTERIM="$PROJECT_DIR/data/interim/rna"
PROCESSED="$PROJECT_DIR/data/processed/rna"
QC_OUT="$PROJECT_DIR/results/qc/rna"
REF_DIR="$PROJECT_DIR/ref"

# === 线程数（按CPU调整）===
THREADS=8

# === 参考基因组（可用 00_fetch_reference.sh 下载）===
GENOME_FA="$REF_DIR/Mus_musculus.GRCm39.dna.primary_assembly.fa.gz"
GTF="$REF_DIR/Mus_musculus.GRCm39.109.gtf.gz"
STAR_INDEX="$REF_DIR/star_index"

# === 批次名称（按需增删）===
BATCHES=("batch1" "batch2" "batch3")

# === 链特异性（0=unstranded；1=正链；2=反链；不确定先用0）===
STRANDNESS=0

# === R1 文件名匹配（支持 *_R1*.fastq.gz 或 *_1.fastq.gz / .fq.gz）===
R1_PATTERNS=("*_R1*.f*q.gz" "*_1.f*q.gz")
